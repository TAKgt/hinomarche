# ===== ヒノマルシェ 環境変数 =====
# このファイルを .env.local にコピーして値を埋めてください。
# 何も設定しない場合はデモモード(サンプル商品表示)で動きます。

# --- サイトURL (sitemap / robots 用。本番では https://www.hinomarche.com を設定) ---
# NEXT_PUBLIC_SITE_URL=https://www.hinomarche.com

# --- Supabase (https://supabase.com → プロジェクト作成 → Settings > API) ---
SUPABASE_URL=
# 公開ページの読み取り用。RLSを効かせるため本番では設定推奨
SUPABASE_ANON_KEY=
# 収集・判定保存用。サーバー専用、ブラウザ公開禁止
SUPABASE_SERVICE_ROLE_KEY=

# --- 楽天 (https://webservice.rakuten.co.jp → アプリ登録) ---
# 2026年の新API仕様: 管理画面の「アプリケーションID」(UUID形式)と「アクセスキー」の両方が必要
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=

# --- もしもアフィリエイト (管理画面 → 楽天市場のプロモーション → a_id) ---
MOSHIMO_A_ID=
# もしもの「どこでもリンク」のURLに含まれる p_id / pc_id / pl_id が
# 下記デフォルト(楽天市場用)と違う場合のみ設定
# MOSHIMO_RAKUTEN_P_ID=54
# MOSHIMO_RAKUTEN_PC_ID=54
# MOSHIMO_RAKUTEN_PL_ID=616

# --- Amazon Creators API (アソシエイト管理画面 → ツール → Creators API で認証情報を発行) ---
# ※旧PA-APIは2026年5月に廃止。Creators APIのcredential ID/secretを使う
AMAZON_CREDENTIAL_ID=
AMAZON_CREDENTIAL_SECRET=
# トラッキングID (例: xxxx-22)
AMAZON_PARTNER_TAG=
# 認証情報のバージョン(日本で発行したLWA認証情報は通常3.3)
# AMAZON_CREDS_VERSION=3.3

# --- Claude API (https://platform.claude.com → API Keys) AI判定に使用 ---
ANTHROPIC_API_KEY=
# JUDGE_MODEL=claude-haiku-4-5

# --- Vercel Cron 認証用シークレット(ランダムな長い文字列を設定) ---
CRON_SECRET=

# --- 運営ランキング画面(/admin/ranking) Basic認証 ---
# 未設定時は常に503で閉じる。強力なランダム値をVercelにだけ設定する
# ANALYTICS_ADMIN_USERNAME=hinomarche
ANALYTICS_ADMIN_PASSWORD=

# --- 1回の収集で新規にAI判定する商品数の上限 ---
# INGEST_MAX_NEW=30
# --- 1カテゴリあたり1日に検索するキーワード数(日替わり巡回) ---
# INGEST_KEYWORDS_PER_CATEGORY=2
# ローカルで特定カテゴリだけ収集する場合(カンマ区切り。本番Cronでは通常未設定)
# INGEST_CATEGORY_SLUGS=smartphone,computer

# --- 低スコア(日本度49%以下)商品の表示トグル ---
# false にするとサイト上から低スコア商品を非表示にできる(データは残るので即戻せる)
# SHOW_LOW_TIER=true
